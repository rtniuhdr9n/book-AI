<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bookai.mapper.BookCategoryMapper">

    <select id="selectByParentId" resultType="com.bookai.entity.BookCategory">
        SELECT *
        FROM book_category
        WHERE parent_id = #{parentId}
        ORDER BY sort ASC
    </select>

    <select id="selectAllTree" resultType="com.bookai.entity.BookCategory">
        SELECT *
        FROM book_category
        ORDER BY level ASC, sort ASC
    </select>

</mapper>
